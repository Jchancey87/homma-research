# Trading Journal — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Database (PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://journal:journal@localhost:5432/trading_journal
STORAGE_PATH=../storage/charts

# ── Primary LLM (OpenRouter — for fast daily tasks) ──────────────────────
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-YOUR_KEY_HERE
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Secondary LLM (OpenRouter / OpenAI — for Deep Research) ──────────────
DEEP_LLM_BASE_URL=https://openrouter.ai/api/v1
DEEP_LLM_API_KEY=sk-or-v1-YOUR_KEY_HERE
# OpenRouter Deep Model (e.g. deepseek/deepseek-r1 or meta-llama/llama-3.3-70b-instruct)
DEEP_LLM_MODEL=deepseek/deepseek-r1

# ── External APIs ────────────────────────────────────────────────────────
# Market data (OHLCV, news, gainers snapshot). Polygon.io rebranded to Massive.com (Oct 2025).
# Your existing polygon.io key works unchanged. Get new keys at: https://massive.com/dashboard/api-keys
# SDK: pip install -U massive  (replaces polygon-api-client)
POLYGON_API_KEY=YOUR_POLYGON_KEY_HERE
# Free — 250 req/day. Get your key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=YOUR_FMP_KEY_HERE
GEMINI_API_KEY=
# Required by SEC EDGAR — use your real name + email (free, no registration)
SEC_USER_AGENT=YourName your@email.com

# ── Email Notifications (SMTP) ───────────────────────────────────────────
# If using Gmail, use an App Password for SMTP_PASSWORD
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# ── Telegram Bot Settings ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

