# Trading Journal — Backend Environment Template
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://journal:journal1@localhost:5432/trading_journal?sslmode=disable
STORAGE_PATH=../storage/charts

# ── Primary LLM (OpenRouter) ──────────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Secondary LLM (OpenRouter) ───────────────────────────────────────────────
DEEP_LLM_BASE_URL=https://openrouter.ai/api/v1
DEEP_LLM_API_KEY=YOUR_DEEP_LLM_API_KEY_HERE
DEEP_LLM_MODEL=deepseek/deepseek-r1

# ── External APIs ────────────────────────────────────────────────────────────
POLYGON_API_KEY=YOUR_POLYGON_KEY_HERE
FMP_API_KEY=YOUR_FMP_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
SEC_USER_AGENT=YourName your@email.com

# ── Schwab API ────────────────────────────────────────────────────────────────
SCHWAB_API_KEY=YOUR_SCHWAB_API_KEY_HERE
SCHWAB_API_SECRET=YOUR_SCHWAB_API_SECRET_HERE
SCHWAB_CALLBACK_URL=https://127.0.0.1
SCHWAB_TOKEN_PATH=/home/jackc/.config/schwab/token.json

# ── Email Notifications ───────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# ── Celery & Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Telegram Bot Settings ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── Alert Cooldown & Tuning Settings ──────────────────────────────────────────
# Minimum price increase percentage (e.g. 0.03 = 3%) for a new alert on the same ticker during lockout
ALERT_MIN_PCT_INCREASE=0.03
# Minimum time cooldown in minutes before a new alert can trigger on the same ticker during lockout
ALERT_MIN_TIME_COOLDOWN_MINUTES=2
